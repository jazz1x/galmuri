{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [{ "type": "command", "command": "hooks/shims/pre-write.sh" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "hooks/shims/post-write.sh" },
          { "type": "command", "command": "hooks/shims/asset-record.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {"hooks": [{ "type": "command", "command": "hooks/shims/prompt-hint.sh" }]},
      {"hooks": [{ "type": "command", "command": "hooks/shims/source-capture.sh" }]}
    ],
    "SessionStart": [{
      "hooks": [{ "type": "command", "command": "hooks/shims/session-start.sh" }]
    }]
  }
}
